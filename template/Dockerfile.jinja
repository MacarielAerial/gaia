# syntax=docker/dockerfile:1.7

# Global Build Arguments
ARG PYTHON_VERSION={{  python_version  }}
ARG USERNAME={{ project_slug }}-svc
ARG USER_UID=1000
ARG USER_GID=${USER_UID}

# ==============================================================================
# Multi Stage: Base
# ==============================================================================

FROM python:${PYTHON_VERSION}-slim AS base

# Copy binary from the official image
COPY --from=ghcr.io/astral-sh/uv:{{  uv_version  }} /uv /uvx /bin/

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_COMPILE_BYTECODE=1

# =========================
# Multi Stage: Dev
# =========================
FROM base AS dev

# Specific username to be used with VSCode Dev Container
ARG USERNAME=vscode
ARG USER_UID=1000
ARG USER_GID=${USER_UID}

# Avoid the uv hardlinking warning
ENV UV_LINK_MODE=copy

# Install system dependencies
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        pkg-config \
        ca-certificates \
        curl \
        git \
        git-lfs \
        just \
        openssh-client \
        sudo \
    && rm -rf /var/lib/apt/lists/*

# Copy system dependency installation shell scripts over
COPY scripts/ /tmp/scripts/

# Make them executable
RUN chmod +x /tmp/scripts/*.sh

# Make sure Cargo is reachable by the unprivileged user
ENV CARGO_HOME=/usr/local/cargo \
    RUSTUP_HOME=/usr/local/rustup \
    PATH=/usr/local/cargo/bin:$PATH

# Install system dependencies not available in the package manager
RUN /tmp/scripts/install-cargo.sh

# Install just-lsp with cargo
RUN cargo install just-lsp

# Add the non-root user
RUN groupadd --gid "${USER_GID}" "${USERNAME}" \
    && useradd \
        --uid "${USER_UID}" \
        --gid "${USER_GID}" \
        --create-home \
        --shell /bin/bash \
        "${USERNAME}" \
    && install -d -m 0755 /etc/sudoers.d \
    && echo "${USERNAME} ALL=(ALL) NOPASSWD:ALL" > "/etc/sudoers.d/${USERNAME}" \
    && chmod 0440 "/etc/sudoers.d/${USERNAME}" \
    && visudo -cf "/etc/sudoers.d/${USERNAME}"

# Switch to the non-root user to install applications on the user level
USER ${USERNAME}

# =========================
# Multi Stage: Bake
# =========================

FROM base AS bake

# Arguments associated with the non-root user
ARG USERNAME
ARG USER_UID
ARG USER_GID

# Set environemntal variables
ENV UV_NO_DEV=1

# Add the non-root user
RUN groupadd --gid "${USER_GID}" "${USERNAME}" \
    && useradd --uid "${USER_UID}" --gid "${USER_GID}" -m "${USERNAME}" -s /usr/sbin/nologin

# Make working directory
RUN mkdir -p /app && chown "${USER_UID}:${USER_GID}" /app

# Switch to working directory
WORKDIR /app

# Copy over python dependency metadata
COPY --chown=${USERNAME}:${USERNAME} pyproject.toml uv.lock README.md ./

# Switch to the non-root user to install applications on the user level
USER ${USERNAME}

# Install python dependencies
RUN uv sync --frozen --no-dev --no-install-project

# Copy over source code
COPY --chown=${USERNAME}:${USERNAME} src ./src

# Install source application
RUN uv sync --frozen --no-dev --no-editable

# =========================
# Multi Stage: Live
# =========================

FROM python:${PYTHON_VERSION}-slim AS live

# Reference build arguments
ARG USERNAME
ARG USER_UID
ARG USER_GID
ARG APP_HOST=0.0.0.0
ARG APP_PORT=8000

# Set environemntal variables
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    APP_HOST=$APP_HOST \
    APP_PORT=$APP_PORT

# Add the non-root user
RUN groupadd --gid "${USER_GID}" "${USERNAME}" \
    && useradd --uid "${USER_UID}" --gid "${USER_GID}" -m "${USERNAME}" -s /usr/sbin/nologin

# Make working directory
RUN mkdir -p /app && chown "${USER_UID}:${USER_GID}" /app

# Switch to working directory
WORKDIR /app

# Copy over baked environment
COPY --from=bake --chown=${USERNAME}:${USERNAME} /app/.venv /app/.venv

# Switch to the non-root user
USER ${USERNAME}

# Set executables in PATH
ENV PATH="/app/.venv/bin:$PATH"

# Expose the service port
EXPOSE $APP_PORT

# Auto start the fastapi service on start-up
CMD ["sh", "-c", "exec uvicorn {{ package_name }}.main:app --host \"$APP_HOST\" --port \"$APP_PORT\""]
