name: {{  project_slug  }}-dev

services:
  {{  project_slug  }}:
    build:
      context: .
      dockerfile: Dockerfile
      # Overwrite the main file to use dev stage
      target: dev
    image: {{  project_slug  }}:latest
    # Prevent the container from exiting after initialisation
    command: sleep infinity
    init: true
    volumes:
      # Mount the source directory
      - .:/home/vscode/workspaces/{{  package_name  }}

      # Enable Testcontainers by allowing the devcontainer to talk to the host Docker daemon
      - /var/run/docker.sock:/var/run/docker.sock
