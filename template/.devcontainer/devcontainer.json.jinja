{
	"name": "{{  project_slug }}",
	"dockerComposeFile": [
		"../docker-compose.yml",
		"docker-compose.yml"
	],
	"service": "{{  project_slug  }}",
	"workspaceFolder": "/vscode/workspaces/{{  package_name  }}",
	"shutdownAction": "stopCompose",
    "mounts": [
        // Mount the SSH key folder to share with the host process
        "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,readonly,type=bind"
    ],
	"customizations": {
		"vscode": {
			"settings": {
				"python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python",
				"python.testing.pytestEnabled": true,
				"python.analysis.autoImportCompletions": true,
				"python.analysis.typeCheckingMode": "basic",
				"terminal.integrated.defaultProfile.linux": "bash",
				"terminal.integrated.profiles.linux": {"bash": {"path": "bash"}},
				"editor.formatOnSave": true,
				"editor.codeActionsOnSave": {
				"source.fixAll": "explicit",
				"source.organizeImports": "explicit"
				}
			},
			"extensions": [
				"vscodevim.vim",
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-python.mypy-type-checker",
				"charliermarsh.ruff",
				"ms-toolsai.jupyter",
				"mechatroner.rainbow-csv",
				"tamasfe.even-better-toml",
				"davidanson.vscode-markdownlint",
				"ms-azuretools.vscode-containers",
				"github.vscode-github-actions",
				"wholroyd.jinja",
				"nefrob.vscode-just-syntax"
			]
		}
	},
	"remoteUser": "vscode"
}
